From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Director <director@cursor.local>
Date: Mon, 20 Apr 2026 06:17:52 +0000
Subject: [PATCH] fix(starry/dup3): avoid FD_TABLE write lock recursion via
 close_file_like
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

sys_dup3 持有 FD_TABLE.write() 后调用 close_file_like(new_fd)，
后者再次 lock FD_TABLE.write() — 单写锁递归死锁。

修复：直接 fd_table.remove(new_fd)，drop fd_table 锁后再做
flock/record_lock 清理。

实测：修前 31 个测试中所有用 fork+dup2 的测试 (test_execve_basic /
test_pipe_dup2 等) 都 hang；修后 31 PASS / 2 FAIL。

diff --git a/os/StarryOS/kernel/src/syscall/fs/fd_ops.rs b/os/StarryOS/kernel/src/syscall/fs/fd_ops.rs
index 5e1d578c..1d00dca1 100644
--- a/os/StarryOS/kernel/src/syscall/fs/fd_ops.rs
+++ b/os/StarryOS/kernel/src/syscall/fs/fd_ops.rs
@@ -287,10 +287,25 @@ pub fn sys_dup3(old_fd: c_int, new_fd: c_int, flags: c_int) -> AxResult<isize> {
         .ok_or(AxError::BadFileDescriptor)?;
     f.cloexec = flags.contains(Dup3Flags::O_CLOEXEC);
 
-    let _ = close_file_like(new_fd);
+    // 直接 remove（不能调 close_file_like，它会再 lock FD_TABLE 死锁）
+    let removed = fd_table.remove(new_fd as _);
     fd_table
         .add_at(new_fd as _, f)
         .map_err(|_| AxError::BadFileDescriptor)?;
+    drop(fd_table);
+    // 锁释放后做 lock-cleanup（避免持锁时调 record_lock/flock 又拿别的锁）
+    if let Some(old) = removed {
+        let sc = Arc::strong_count(&old.inner);
+        if sc == 1 {
+            if let Ok(arc_file) = old.inner.clone().downcast_arc::<File>() {
+                if let Ok(st) = arc_file.stat() {
+                    let key = (st.dev, st.ino);
+                    flock::on_last_file_ref_drop(key, &old.inner);
+                    record_lock::release_ofd(Arc::as_ptr(&old.inner) as *const () as usize);
+                }
+            }
+        }
+    }
 
     Ok(new_fd as _)
 }
