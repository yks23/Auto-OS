+pub fn sys_getresuid(ruid: *mut u32, euid: *mut u32, suid: *mut u32) -> AxResult<isize> {
+    let (r, e, s) = current().as_thread().proc_data.res_uids();
+    if let Some(p) = ruid.nullable() {
+        p.vm_write(r)?;
+    }
+    if let Some(p) = euid.nullable() {
