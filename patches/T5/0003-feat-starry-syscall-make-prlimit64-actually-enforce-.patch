diff --git a/os/StarryOS/kernel/src/syscall/task/execve.rs b/os/StarryOS/kernel/src/syscall/task/execve.rs
index 614d3d40..51ba633e 100644
--- a/os/StarryOS/kernel/src/syscall/task/execve.rs
+++ b/os/StarryOS/kernel/src/syscall/task/execve.rs
@@ -7,11 +7,13 @@ use ax_hal::uspace::UserContext;
 use ax_task::current;
 use starry_vm::vm_load_until_nul;
 
+use linux_raw_sys::general::RLIMIT_STACK;
+
 use crate::{
-    config::USER_HEAP_BASE,
+    config::{USER_HEAP_BASE, USER_STACK_SIZE},
     file::FD_TABLE,
     mm::{load_user_app, vm_load_string},
-    task::AsThread,
+    task::{AsThread, rlim_is_infinite},
 };
 
 pub fn sys_execve(
@@ -53,9 +55,19 @@ pub fn sys_execve(
         return Err(AxError::WouldBlock);
     }
 
+    let stack_bytes = {
+        let r = proc_data.rlim.read();
+        let sz = r[RLIMIT_STACK].current;
+        if rlim_is_infinite(sz) {
+            USER_STACK_SIZE
+        } else {
