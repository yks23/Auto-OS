     let ustack_top = VirtAddr::from_usize(crate::config::USER_STACK_TOP);
-    let ustack_size = crate::config::USER_STACK_SIZE;
+    let ustack_size = user_stack_size
+        .max(PAGE_SIZE_4K * 4)
