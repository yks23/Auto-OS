From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Cursor Agent <cursoragent@cursor.com>
Date: Sat, 18 Apr 2026 19:18:43 +0000
Subject: [PATCH] feat(starry/syscall): make prlimit64 actually enforce
 RLIMIT_{STACK,AS,DATA,NOFILE,NPROC}

Wire rlimits into brk, mmap, clone fork inheritance, exec stack mapping, and fix prlimit64 set semantics.

Made-with: Cursor

diff --git a/os/StarryOS/kernel/src/entry.rs b/os/StarryOS/kernel/src/entry.rs
index 52407d89..dd040d73 100644
--- a/os/StarryOS/kernel/src/entry.rs
+++ b/os/StarryOS/kernel/src/entry.rs
@@ -37,8 +37,14 @@ pub fn init(args: &[String], envs: &[String]) {
         })
         .expect("Failed to create user address space");
 
-    let (entry_vaddr, ustack_top) = load_user_app(&mut uspace, None, args, envs)
-        .unwrap_or_else(|e| panic!("Failed to load user app: {}", e));
+    let (entry_vaddr, ustack_top) = load_user_app(
+        &mut uspace,
+        None,
+        args,
+        envs,
+        crate::config::USER_STACK_SIZE,
+    )
+    .unwrap_or_else(|e| panic!("Failed to load user app: {}", e));
 
     let uctx = UserContext::new(entry_vaddr.into(), ustack_top, 0);
     let mut task = new_user_task(name, uctx, 0);
diff --git a/os/StarryOS/kernel/src/mm/aspace/mod.rs b/os/StarryOS/kernel/src/mm/aspace/mod.rs
index 7318e55e..9deea036 100644
--- a/os/StarryOS/kernel/src/mm/aspace/mod.rs
+++ b/os/StarryOS/kernel/src/mm/aspace/mod.rs
@@ -377,6 +377,11 @@ impl AddrSpace {
     pub fn areas(&self) -> impl Iterator<Item = &MemoryArea<Backend>> {
         self.areas.iter()
     }
+
+    /// Total virtual size of all mapped areas (for `RLIMIT_AS` checks).
+    pub fn mapped_virtual_bytes(&self) -> usize {
+        self.areas().map(|a| a.size()).sum()
+    }
 }
 
 impl fmt::Debug for AddrSpace {
