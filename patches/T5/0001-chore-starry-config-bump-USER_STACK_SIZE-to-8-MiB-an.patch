From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Cursor Agent <cursoragent@cursor.com>
Date: Sat, 18 Apr 2026 19:18:38 +0000
Subject: [PATCH] chore(starry/config): bump USER_STACK_SIZE to 8 MiB and heap
 max to 2 GiB

Made-with: Cursor

diff --git a/os/StarryOS/kernel/src/config/aarch64.rs b/os/StarryOS/kernel/src/config/aarch64.rs
index da9896d0..1bee9d6e 100644
--- a/os/StarryOS/kernel/src/config/aarch64.rs
+++ b/os/StarryOS/kernel/src/config/aarch64.rs
@@ -9,14 +9,14 @@ pub const USER_SPACE_SIZE: usize = 0x7fff_ffff_f000;
 /// The highest address of the user stack.
 pub const USER_STACK_TOP: usize = 0x7fff_0000_0000;
 /// The size of the user stack.
-pub const USER_STACK_SIZE: usize = 0x8_0000;
+pub const USER_STACK_SIZE: usize = 0x80_0000;
 
 /// The lowest address of the user heap.
 pub const USER_HEAP_BASE: usize = 0x4000_0000;
 /// The size of the user heap.
 pub const USER_HEAP_SIZE: usize = 0x1_0000;
 /// The maximum size of the user heap (for brk expansion).
-pub const USER_HEAP_SIZE_MAX: usize = 0x2000_0000;
+pub const USER_HEAP_SIZE_MAX: usize = 0x8000_0000;
 
 /// The base address for user interpreter.
 pub const USER_INTERP_BASE: usize = 0x400_0000;
diff --git a/os/StarryOS/kernel/src/config/loongarch64.rs b/os/StarryOS/kernel/src/config/loongarch64.rs
index 55dab7c4..032460a3 100644
--- a/os/StarryOS/kernel/src/config/loongarch64.rs
+++ b/os/StarryOS/kernel/src/config/loongarch64.rs
@@ -9,14 +9,14 @@ pub const USER_SPACE_SIZE: usize = 0x3f_ffff_f000;
 /// The highest address of the user stack.
 pub const USER_STACK_TOP: usize = 0x4_0000_0000;
 /// The size of the user stack.
-pub const USER_STACK_SIZE: usize = 0x8_0000;
+pub const USER_STACK_SIZE: usize = 0x80_0000;
 
 /// The lowest address of the user heap.
 pub const USER_HEAP_BASE: usize = 0x4000_0000;
 /// The size of the user heap.
 pub const USER_HEAP_SIZE: usize = 0x1_0000;  // 64KB
 /// The maximum size of the user heap (for brk expansion).
-pub const USER_HEAP_SIZE_MAX: usize = 0x2000_0000;  // 512MB
+pub const USER_HEAP_SIZE_MAX: usize = 0x8000_0000;  // 2 GiB
 
 /// The base address for user interpreter.
 pub const USER_INTERP_BASE: usize = 0x400_0000;
diff --git a/os/StarryOS/kernel/src/config/riscv64.rs b/os/StarryOS/kernel/src/config/riscv64.rs
index fc970e89..33960d43 100644
--- a/os/StarryOS/kernel/src/config/riscv64.rs
+++ b/os/StarryOS/kernel/src/config/riscv64.rs
@@ -9,14 +9,14 @@ pub const USER_SPACE_SIZE: usize = 0x3f_ffff_f000;
 /// The highest address of the user stack.
 pub const USER_STACK_TOP: usize = 0x4_0000_0000;
 /// The size of the user stack.
-pub const USER_STACK_SIZE: usize = 0x8_0000;
+pub const USER_STACK_SIZE: usize = 0x80_0000;
 
 /// The lowest address of the user heap.
 pub const USER_HEAP_BASE: usize = 0x4000_0000;
 /// The size of the user heap.
 pub const USER_HEAP_SIZE: usize = 0x1_0000;
 /// The maximum size of the user heap (for brk expansion).
-pub const USER_HEAP_SIZE_MAX: usize = 0x2000_0000;
+pub const USER_HEAP_SIZE_MAX: usize = 0x8000_0000;
 
 /// The base address for user interpreter.
 pub const USER_INTERP_BASE: usize = 0x400_0000;
diff --git a/os/StarryOS/kernel/src/config/x86_64.rs b/os/StarryOS/kernel/src/config/x86_64.rs
index da9896d0..1bee9d6e 100644
--- a/os/StarryOS/kernel/src/config/x86_64.rs
+++ b/os/StarryOS/kernel/src/config/x86_64.rs
@@ -9,14 +9,14 @@ pub const USER_SPACE_SIZE: usize = 0x7fff_ffff_f000;
 /// The highest address of the user stack.
 pub const USER_STACK_TOP: usize = 0x7fff_0000_0000;
 /// The size of the user stack.
-pub const USER_STACK_SIZE: usize = 0x8_0000;
+pub const USER_STACK_SIZE: usize = 0x80_0000;
 
 /// The lowest address of the user heap.
 pub const USER_HEAP_BASE: usize = 0x4000_0000;
 /// The size of the user heap.
 pub const USER_HEAP_SIZE: usize = 0x1_0000;
 /// The maximum size of the user heap (for brk expansion).
-pub const USER_HEAP_SIZE_MAX: usize = 0x2000_0000;
+pub const USER_HEAP_SIZE_MAX: usize = 0x8000_0000;
 
 /// The base address for user interpreter.
 pub const USER_INTERP_BASE: usize = 0x400_0000;
