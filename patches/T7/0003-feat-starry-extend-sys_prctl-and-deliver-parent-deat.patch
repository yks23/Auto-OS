 }
 
+fn deliver_parent_death_signal_to_children(process: &Process) {
+    for child in process.children() {
+        let Ok(child_data) = get_process_data(child.pid()) else {
+            continue;
+        };
+        let raw = child_data.pdeath_signal();
+        if raw == 0 {
+            continue;
+        }
+        let Some(signo) = Signo::from_repr(raw as u8) else {
+            continue;
+        };
+        if signo == Signo::SIGKILL {
+            continue;
+        }
+        let _ = send_signal_to_process(
+            child.pid(),
+            Some(SignalInfo::new_kernel(signo)),
+        );
+    }
+}
+
 pub fn do_exit(exit_code: i32, group_exit: bool) {
     let curr = current();
     let thr = curr.as_thread();
